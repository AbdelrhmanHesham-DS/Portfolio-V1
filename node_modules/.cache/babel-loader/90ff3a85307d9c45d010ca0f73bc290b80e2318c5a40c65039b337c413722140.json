{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      toRotate: [\"Backend Developer\", \"Computer Science Student\"],\n      period: 2000,\n      txt: '',\n      loopNum: 0,\n      isDeleting: false\n    };\n  },\n  mounted() {\n    this.$nextTick(() => {\n      this.tick();\n    });\n  },\n  methods: {\n    tick() {\n      let typewriter = this.$refs.typewriter;\n      if (!typewriter) return;\n      let i = this.loopNum % this.toRotate.length;\n      let fullTxt = this.toRotate[i];\n      this.txt = this.isDeleting ? fullTxt.substring(0, this.txt.length - 1) : fullTxt.substring(0, this.txt.length + 1);\n      typewriter.innerHTML = `<span class=\"wrap\">${this.txt}</span>`;\n      let delta = 200 - Math.random() * 100;\n      if (this.isDeleting) delta /= 2;\n      if (!this.isDeleting && this.txt === fullTxt) {\n        delta = this.period;\n        this.isDeleting = true;\n      } else if (this.isDeleting && this.txt === '') {\n        this.isDeleting = false;\n        this.loopNum++;\n        delta = 500;\n      }\n      setTimeout(() => this.tick(), delta);\n    },\n    redirectToHome() {\n      this.$router.push('/');\n    }\n  }\n};","map":{"version":3,"names":["name","data","toRotate","period","txt","loopNum","isDeleting","mounted","$nextTick","tick","methods","typewriter","$refs","i","length","fullTxt","substring","innerHTML","delta","Math","random","setTimeout","redirectToHome","$router","push"],"sources":["D:\\githup\\Portfolio\\src\\App.vue"],"sourcesContent":["<template>\n  <div class=\"max-w-7xl mx-auto flex flex-col relative\">\n    <nav\n      class=\"w-full px-4 sm:px-6 lg:px-8 md:fixed top-0 z-50 backdrop-blur-md bg-[#101010] bg-opacity-90 border-b border-[#2a2a2a]\">\n      <div class=\"flex flex-wrap items-center justify-between py-4\">\n        <button @click=\"redirectToHome\" class=\"flex items-center\">\n          <span class=\"text-xl font-bold text-red-500 tracking-tight hover:text-white transition\">Eng.Abdelrhman(D3ff4ult);</span>\n        </button>\n        <div class=\"hidden md:flex space-x-6 text-sm font-medium\">\n          <router-link to=\"/\" class=\"text-gray-300 hover:text-white transition\">Home</router-link>\n          <router-link to=\"/about\" class=\"text-gray-300 hover:text-white transition\">About</router-link>\n          <router-link to=\"/portfolio\" class=\"text-gray-300 hover:text-white transition\">Projects</router-link>\n          <router-link to=\"/contact\" class=\"text-gray-300 hover:text-white transition\">Contact</router-link>\n        </div>\n      </div>\n    </nav>\n\n    <main\n      class=\"mt-24 flex flex-col-reverse gap-8 items-center md:flex-row md:gap-16 md:justify-center min-h-[65vh] md:min-h-[80vh] px-4 sm:px-6 lg:px-8\">\n      <div class=\"space-y-2 text-center md:text-left\">\n        <p class=\"text-red-500 font-medium text-base md:text-lg fade-in-from-left\">Hello World, I'm</p>\n        <h1 class=\"text-4xl font-bold md:text-5xl text-gray-300 fadein-up\">Eng. Abdelrhman | D3ff4ult</h1>\n        <div class=\"py-2\">\n          <h1\n            class=\"typewrite text-xl md:text-2xl font-semibold text-transparent bg-clip-text bg-gradient-to-r from-slate-100 to-yellow-500 fadein-up\"\n            ref=\"typewriter\">\n            <span class=\"wrap\">{{ txt }}</span>\n          </h1>\n        </div>\n        <p class=\"text-red-500 text-base md:text-lg fade-in-from-left\">Welcome to my personal website <span class=\"wave\">👋🏼</span></p>\n      </div>\n      <div class=\"flex justify-center md:justify-start fadein-right\">\n        <img \n          src=\"/img/me.jpg\" \n          alt=\"My Avatar\"\n          class=\"w-32 h-32 sm:w-40 sm:h-40 md:w-48 md:h-48 lg:w-56 lg:h-56 object-cover rounded-full border-4 border-red-500 shadow-lg transition-all duration-300 hover:scale-105\"\n        />\n      </div>\n    </main>\n\n    <footer class=\"bg-[#0f0f0f] border-t border-[#2c2c2c] text-gray-300 py-10 px-4 sm:px-6 lg:px-8\">\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 text-sm\">\n        <div>\n          <h2 class=\"text-lg font-semibold text-red-500 mb-3\">Information</h2>\n          <p>Back-end developer crafting modern sites</p>\n        </div>\n        <div>\n          <h3 class=\"text-red-400 font-semibold mb-2\">Quick Links</h3>\n          <ul class=\"space-y-1\">\n            <li><router-link to=\"/\" class=\"hover:text-white transition\">Home</router-link></li>\n            <li><router-link to=\"/about\" class=\"hover:text-white transition\">About</router-link></li>\n            <li><router-link to=\"/portfolio\" class=\"hover:text-white transition\">Projects</router-link></li>\n            <li><router-link to=\"/contact\" class=\"hover:text-white transition\">Contact</router-link></li>\n          </ul>\n        </div>\n        <div>\n          <h3 class=\"text-red-400 font-semibold mb-2\">Contact Info</h3>\n          <ul class=\"space-y-1\">\n            <li>Email: <a href=\"mailto:abdoh6112113@gmail.com\" class=\"hover:text-white transition\">abdoh6112113@gmail.com</a></li>\n            <li>Phone: <a href=\"tel:+201149969986\" class=\"hover:text-white transition\">+20 114 996 9986</a></li>\n            <li>Location: Giza, Egypt</li>\n          </ul>\n        </div>\n      </div>\n      <div class=\"flex justify-center gap-4 mt-8\">\n        <a href=\"https://github.com/d3ff4ult\" class=\"w-10 h-10 flex items-center justify-center rounded-full bg-gray-800 text-red-500 hover:text-white transition\"><i class=\"fab fa-github\"></i></a>\n      </div>\n      <div class=\"mt-6 text-center text-gray-500 text-xs\">© {{ new Date().getFullYear() }} D3ff4ult. All rights reserved.</div>\n    </footer>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'HomeView',\n  data() {\n    return {\n      toRotate: [\"Backend Developer\", \"Computer Science Student\"],\n      period: 2000,\n      txt: '',\n      loopNum: 0,\n      isDeleting: false,\n    };\n  },\n  mounted() {\n    this.$nextTick(() => {\n      this.tick();\n    });\n  },\n  methods: {\n    tick() {\n      let typewriter = this.$refs.typewriter;\n      if (!typewriter) return;\n      let i = this.loopNum % this.toRotate.length;\n      let fullTxt = this.toRotate[i];\n      this.txt = this.isDeleting\n        ? fullTxt.substring(0, this.txt.length - 1)\n        : fullTxt.substring(0, this.txt.length + 1);\n      typewriter.innerHTML = `<span class=\"wrap\">${this.txt}</span>`;\n      let delta = 200 - Math.random() * 100;\n      if (this.isDeleting) delta /= 2;\n      if (!this.isDeleting && this.txt === fullTxt) {\n        delta = this.period;\n        this.isDeleting = true;\n      } else if (this.isDeleting && this.txt === '') {\n        this.isDeleting = false;\n        this.loopNum++;\n        delta = 500;\n      }\n      setTimeout(() => this.tick(), delta);\n    },\n    redirectToHome() {\n      this.$router.push('/')\n    }\n  }\n}\n</script>\n\n<style>\nbody {\n  overflow-y: scroll;\n  overflow-x: hidden;\n  font-family: 'Poppins', sans-serif;\n  background: #121212;\n  color: #d1d5db;\n}\n\n.typewrite>.wrap {\n  border-right: 0.08em solid #fff;\n}\n\n.wave {\n  animation-name: wave-animation;\n  animation-duration: 2.5s;\n  animation-iteration-count: infinite;\n  transform-origin: 70% 70%;\n  display: inline-block;\n}\n\n@keyframes wave-animation {\n  0%, 60%, 100% { transform: rotate(0deg); }\n  10%, 30% { transform: rotate(14deg); }\n  20%, 40% { transform: rotate(-8deg); }\n  50% { transform: rotate(10deg); }\n}\n\n.fadein-up {\n  opacity: 0;\n  animation-name: fadeInUp;\n  animation-duration: 0.5s;\n  animation-fill-mode: forwards;\n  animation-delay: 500ms;\n}\n\n@keyframes fadeInUp {\n  from { opacity: 0; transform: translate3d(0, 100%, 0); }\n  to { opacity: 1; transform: translate3d(0, 0, 0); }\n}\n\n.fade-in-from-left {\n  opacity: 0;\n  animation: fadeInLeft 0.5s ease-out forwards;\n  animation-delay: 500ms;\n}\n\n@keyframes fadeInLeft {\n  0% { opacity: 0; transform: translateX(-100%); }\n  100% { opacity: 1; transform: translateX(0); }\n}\n\n.fadein-right {\n  opacity: 0;\n  animation: fadeInRight 0.5s ease-out forwards;\n  animation-delay: 500ms;\n}\n\n@keyframes fadeInRight {\n  0% { opacity: 0; transform: translateX(100%); }\n  100% { opacity: 1; transform: translateX(0); }\n}\n</style>\n"],"mappings":";AAyEA,eAAe;EACbA,IAAI,EAAE,UAAU;EAChBC,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,QAAQ,EAAE,CAAC,mBAAmB,EAAE,0BAA0B,CAAC;MAC3DC,MAAM,EAAE,IAAI;MACZC,GAAG,EAAE,EAAE;MACPC,OAAO,EAAE,CAAC;MACVC,UAAU,EAAE;IACd,CAAC;EACH,CAAC;EACDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,SAAS,CAAC,MAAM;MACnB,IAAI,CAACC,IAAI,CAAC,CAAC;IACb,CAAC,CAAC;EACJ,CAAC;EACDC,OAAO,EAAE;IACPD,IAAIA,CAAA,EAAG;MACL,IAAIE,UAAS,GAAI,IAAI,CAACC,KAAK,CAACD,UAAU;MACtC,IAAI,CAACA,UAAU,EAAE;MACjB,IAAIE,CAAA,GAAI,IAAI,CAACR,OAAM,GAAI,IAAI,CAACH,QAAQ,CAACY,MAAM;MAC3C,IAAIC,OAAM,GAAI,IAAI,CAACb,QAAQ,CAACW,CAAC,CAAC;MAC9B,IAAI,CAACT,GAAE,GAAI,IAAI,CAACE,UAAS,GACrBS,OAAO,CAACC,SAAS,CAAC,CAAC,EAAE,IAAI,CAACZ,GAAG,CAACU,MAAK,GAAI,CAAC,IACxCC,OAAO,CAACC,SAAS,CAAC,CAAC,EAAE,IAAI,CAACZ,GAAG,CAACU,MAAK,GAAI,CAAC,CAAC;MAC7CH,UAAU,CAACM,SAAQ,GAAI,sBAAsB,IAAI,CAACb,GAAG,SAAS;MAC9D,IAAIc,KAAI,GAAI,GAAE,GAAIC,IAAI,CAACC,MAAM,CAAC,IAAI,GAAG;MACrC,IAAI,IAAI,CAACd,UAAU,EAAEY,KAAI,IAAK,CAAC;MAC/B,IAAI,CAAC,IAAI,CAACZ,UAAS,IAAK,IAAI,CAACF,GAAE,KAAMW,OAAO,EAAE;QAC5CG,KAAI,GAAI,IAAI,CAACf,MAAM;QACnB,IAAI,CAACG,UAAS,GAAI,IAAI;MACxB,OAAO,IAAI,IAAI,CAACA,UAAS,IAAK,IAAI,CAACF,GAAE,KAAM,EAAE,EAAE;QAC7C,IAAI,CAACE,UAAS,GAAI,KAAK;QACvB,IAAI,CAACD,OAAO,EAAE;QACda,KAAI,GAAI,GAAG;MACb;MACAG,UAAU,CAAC,MAAM,IAAI,CAACZ,IAAI,CAAC,CAAC,EAAES,KAAK,CAAC;IACtC,CAAC;IACDI,cAAcA,CAAA,EAAG;MACf,IAAI,CAACC,OAAO,CAACC,IAAI,CAAC,GAAG;IACvB;EACF;AACF","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}